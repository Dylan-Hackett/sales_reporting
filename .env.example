# Copy this file to `.env` and fill in your MobiWork API credentials.
# Never commit the real `.env` file.

MOBI_API_LOGIN_ID=your-api-login-id
MOBI_API_PASSWORD=your-api-password
MOBI_CLIENT_ID=your-client-id
MOBI_API_VERSION=10.4.109
MOBI_BASE_URL=https://platform.mobiwork.com

# Optional overrides
MOBI_FORM_ID=165008
MOBI_FILLED_FORM_ID=145683277
MOBI_TARGET_CUSTOMER_ID=10812
